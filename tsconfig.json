{
    "compilerOptions": {
      "target": "ES2017",
      "lib": ["DOM", "ES2017"],
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "jsx": "react-jsx",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "noEmit": true
    },
    "include": ["src"]
  }